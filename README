```
law-system/
├── app/
│   ├── frontend/
│   │   ├── index.html          # Tela de login/registro
│   │   └── dash.html           # Dashboard principal
│   ├── api/
│   │   └── routes/             # Rotas organizadas (futuro)
│   ├── core/
│   │   ├── security.py         # JWT e autenticação
│   │   └── email.py            # Envio de e-mails
│   ├── models/
│   │   ├── user.py             # Model de usuário
│   │   └── academic.py         # Models acadêmicos
│   ├── database.py             # Conexão com BD
│   └── main.py                 # Aplicação principal
├── config.py                   # Configurações
├── .env                        # Variáveis de ambiente (NÃO COMMITAR!)
├── .env.example                # Exemplo de .env
├── .gitignore
├── requirements.txt
├── README.md
└── create_admin.py             # Script para criar admin

```

