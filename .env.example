# ════════════════════════════════════════════════════════════════════════
# Law System — Exemplo de variáveis de ambiente
# Copie para .env e preencha. NUNCA commite o .env real.
# ════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────
# Prioridade: POSTGRES_URL > DB_URL > vars individuais
# POSTGRES_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
DB_HOST=localhost
DB_PORT=5432
DB_NAME=law_study_system
DB_USER=study_app
DB_PASSWORD=your_password_here

# ── Security ──────────────────────────────────────────────────────────────
# SECRET_KEY: 32+ chars aleatórios. Gere com:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace_with_random_string_of_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ── Email (opcional — SMTP não usado ativamente ainda) ────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
ADMIN_EMAIL=your_email@gmail.com

# ── Environment ───────────────────────────────────────────────────────────
ENVIRONMENT=production
